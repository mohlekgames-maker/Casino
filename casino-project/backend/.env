# ========================
# GAMEBRED CASINO - ENV
# ========================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=gamebred_casino

# JWT Secrets (change these to random 64-char strings in production!)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_64chars_minimum
JWT_REFRESH_SECRET=another_very_long_random_secret_string_for_refresh_tokens_64chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Game Settings
HOUSE_EDGE=0.05
MIN_BET=1
MAX_BET=10000
STARTING_BALANCE=1000

# Points System
DAILY_LOGIN_POINTS=100
VIDEO_WATCH_POINTS=50
TASK_COMPLETE_POINTS=200
VIDEO_COOLDOWN_SECONDS=30

# Discord OAuth (optional - for Discord login)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:5000/api/auth/discord/callback

# Discord Gifts Webhook (optional)
DISCORD_WEBHOOK_URL=your_discord_webhook_url
DISCORD_SERVER_INVITE=https://discord.gg/your_invite

# Provably Fair Seed (change this!)
SERVER_SEED=your_secret_server_seed_for_provably_fair_games
